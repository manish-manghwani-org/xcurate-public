# What the hourly runner does with the machine after a run, when it's unattended
# (lid closed, no terminal session, no data/stay-awake flag):
#   suspend  -> back to sleep after each run (default; suits a laptop left lid-closed)
#   poweroff -> full shutdown after each run (needs BIOS support for RTC wake from off)
#   none     -> never sleep/shutdown automatically
XCURATE_SLEEP_ACTION=suspend
